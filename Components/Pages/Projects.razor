@page "/projects"

<PageTitle>Projects — Shane Khryss Bantilan</PageTitle>

<div class="page">
    <div class="page-header">
        <span class="page-eyebrow">My Work</span>
        <h2 class="page-title">Featured<br /><em>Projects</em></h2>
    </div>

    <div class="project-card-big">
        <div class="proj-visual">
            <div class="proj-visual-content">
                <span class="proj-emoji">📚</span>
                <span class="proj-label">Video Demo Available</span>
            </div>
        </div>

        <div class="proj-body">
            <span class="proj-num">Project 01 · 2025</span>
            <h3 class="proj-title">Automated Library Logbook</h3>
            <p class="proj-desc">
                A system designed to automate the manual process of logging library visitors. 
                This system was developed as my final project for P.Elec 2 (Web Systems and Technologies).
                It was built using HTML, CSS, and JavaScript. The system only accepts valid student ID 
                records from BSIT 2C students, as these are the only IDs that were collected and used in the system.
            </p>
            <div class="proj-tech">
                <span class="t-chip">HTML</span>
                <span class="t-chip">CSS</span>
                <span class="t-chip">JavaScript</span>
            </div>
            <div class="proj-actions" style="display:flex;gap:1rem;flex-wrap:wrap;">
                <a href="https://drive.google.com/file/d/1C0DvAQJBBmzghGV2m7HyMIpJD_t3VF24/view?usp=drivesdk"
                   target="_blank" class="proj-link">
                    ▶ Watch Demo
                </a>
            </div>
        </div>
    </div>

    <div style="margin-top:3rem;padding:2rem;background:var(--surface);border:1px dashed var(--border-strong);border-radius:var(--radius);text-align:center;">
        <p style="color:var(--text-muted);font-size:0.92rem;font-style:italic;">
            More projects coming soon — currently building and learning every day. 
        </p>
    </div>
</div>

<style>
    .proj-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
</style>
