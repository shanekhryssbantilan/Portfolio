@page "/"

<PageTitle>Shane Khryss Bantilan — Portfolio</PageTitle>

<div class="home-page">
    <div class="home-content">
        <div class="home-eyebrow">Open to opportunities</div>

        <h1 class="home-headline">
            <span class="home-line"><span class="d1"><em class="ital">Designing.</em></span></span>
            <span class="home-line"><span class="d2">Developing.</span></span>
            <span class="home-line"><span class="d3"><em class="ital">Improving.</em></span></span>
        </h1>

        <div class="home-taglines">
            <span class="home-tagline">Driven by curiosity and creativity</span>
            <span class="home-tagline">Committed to growth, consistency, and excellence</span>
        </div>

        <div class="home-cta">
            <a href="projects" class="btn-primary">View My Projects</a>
            <a href="contact" class="btn-ghost">Get In Touch</a>
        </div>
    </div>

    <div class="home-visual">
        <div class="hv-outer">
            <div class="hv-inner">
                <img src="profile.png" alt="Shane Khryss Bantilan"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <span class="hv-initials" style="display:none">SKB</span>
            </div>
            <span class="orbit-dot od1"></span>
            <span class="orbit-dot od2"></span>
            <span class="orbit-dot od3"></span>
        </div>
    </div>
</div>
